{
  "title": "Lancer — Pattern Matcher",
  "uid": "lancer",
  "timezone": "browser",
  "refresh": "10s",
  "time": { "from": "now-3h", "to": "now" },
  "tags": ["crypto", "data", "vectors", "lancedb"],
  "schemaVersion": 39,
  "panels": [
    {
      "id": 1,
      "title": "Top Similarity Score",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "lancer_top_similarity",
          "legendFormat": "{{pair}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.5 },
              { "color": "green", "value": 0.85 }
            ]
          }
        }
      }
    },
    {
      "id": 2,
      "title": "Index Size",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
      "targets": [
        {
          "expr": "lancer_index_size",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": { "steps": [{ "color": "blue", "value": null }] }
        }
      }
    },
    {
      "id": 3,
      "title": "Queries Run",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "lancer_queries_total",
          "legendFormat": "{{pair}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": { "steps": [{ "color": "green", "value": null }] }
        }
      }
    },
    {
      "id": 4,
      "title": "Grafana Annotations Pushed",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 0 },
      "targets": [
        {
          "expr": "lancer_annotations_total",
          "legendFormat": "{{pair}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": { "steps": [{ "color": "orange", "value": null }] }
        }
      }
    },
    {
      "id": 5,
      "title": "Candle Buffer Fill (need 60 for first query)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "lancer_candle_buffer",
          "legendFormat": "{{pair}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "drawStyle": "line", "fillOpacity": 15, "lineWidth": 2 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 60 }
            ]
          }
        }
      }
    },
    {
      "id": 6,
      "title": "Similarity Score Over Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "lancer_top_similarity",
          "legendFormat": "{{pair}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "custom": { "drawStyle": "line", "fillOpacity": 20, "lineWidth": 2 }
        }
      }
    }
  ],
  "schemaVersion": 39
}
