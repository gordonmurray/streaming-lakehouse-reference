# =============================================================================
# Streaming Lakehouse Reference — Environment Configuration
# =============================================================================
# Copy to .env and adjust values as needed.
# This file is checked into git. The .env file is gitignored.

# --- Data Source ---
COINBASE_WS_URL=wss://ws-feed.exchange.coinbase.com
TRADING_PAIRS=BTC-USD,ETH-USD,SOL-USD,DOGE-USD,AVAX-USD,LINK-USD

# --- Iggy (Event Spine) ---
IGGY_HOST=iggy
IGGY_USERNAME=iggy
IGGY_PASSWORD=iggy
IGGY_STREAM=crypto
IGGY_TOPIC=prices
IGGY_TOPIC_PARTITIONS=3
IGGY_HTTP_PORT=3000
IGGY_TCP_PORT=8090
IGGY_UI_PORT=8888
IGGY_REPLAY_TOPIC=replay
IGGY_ORDERS_TOPIC=orders

# --- Poller (Coinbase WebSocket → Iggy) ---
POLLER_METRICS_PORT=8000

# --- Bridge (Iggy → Prometheus) ---
BRIDGE_METRICS_PORT=8001
BRIDGE_POLL_INTERVAL=0.05

# --- Replay (Iceberg → Iggy, on-demand) ---
REPLAY_SPEED=60                     # Replay multiplier (60 = 1 hour in 1 minute)
REPLAY_DATE=                        # Filter by date (YYYY-MM-DD), empty = all
REPLAY_PAIRS=                       # Filter by pairs (comma-separated), empty = all
REPLAY_METRICS_PORT=8002

# --- Lancer (Vector Pattern Matching) ---
LANCER_MODE=signal                  # "signal" (live) or "indexer" (batch)
LANCER_WINDOW_SIZE=60               # Candles per pattern window (60 = 1 hour)
LANCER_TOP_K=5                      # Number of similar patterns to return
LANCER_SIMILARITY_THRESHOLD=0.85    # Annotation threshold (Grafana markers)
LANCER_MIN_OUTCOME_PCT=0.1          # Only return patterns where price rose > 0.1% after
LANCER_API_PORT=8003
LANCER_METRICS_PORT=8004
LANCER_DB_PATH=/data/lancedb

# --- LLM Analyst (Ollama, runs on host) ---
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=mannix/llama3-8b-ablitered-v3
ANALYST_INTERVAL=300                # Seconds between analysis cycles
ANALYST_API_PORT=8005
ANALYST_METRICS_PORT=8006

# --- Consensus Engine (Paper Trading) ---
CONSENSUS_POLL_INTERVAL=60          # Seconds between signal checks
CONSENSUS_TRADE_SIZE_USD=50         # USD per trade (5% of $1K balance)
CONSENSUS_STARTING_BALANCE=1000     # Initial paper trading balance
CONSENSUS_ENTER_SIMILARITY=0.20     # BUY when similarity >= this AND sentiment is Bullish
CONSENSUS_EXIT_SIMILARITY=0.10      # SELL when similarity < this OR sentiment is Bearish
CONSENSUS_API_PORT=8007
CONSENSUS_METRICS_PORT=8008
# Tuning notes:
#   0.05/0.03 = aggressive (100+ trades/day, fee drag dominates)
#   0.20/0.10 = moderate (2-5 trades/day, higher conviction)
#   0.50/0.30 = conservative (rare trades, strong signals only)

# --- Shared Service URLs (used by host-network services) ---
PROMETHEUS_URL=http://localhost:9090
LANCER_URL=http://localhost:8003
GRAFANA_URL=http://localhost:3001
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin

# --- Infrastructure ---
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001
GF_SECURITY_ADMIN_PASSWORD=admin
